# Puerto HTTP del Nest (debe coincidir con el puerto en NEXT_PUBLIC_API_URL del front, sin /api).
PORT=3010

# Si se define, exige Bearer = este valor o JWT de admin (panel). Coincide con INGESTION_SECRET del frontend.
INGESTION_SECRET=

# Firma de JWT para POST /api/auth/login y sesión del panel (distinto de INGESTION_SECRET).
JWT_SECRET=

# Login: intentos fallidos por IP antes de 429 (ventana en ms). Requiere reinicio para aplicar.
# LOGIN_RATE_LIMIT_MAX=10
# LOGIN_RATE_LIMIT_WINDOW_MS=900000
# Primera hop de proxy para @Ip() (login). En despliegue detrás de Nginx suele bastar 1.
# TRUST_PROXY=1

# PostgreSQL (opción A: URL completa)
# Ejemplo: postgresql://usuario:clave@localhost:5432/hkn_platform
DATABASE_URL=

# PostgreSQL (opción B: variables separadas)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=hkn_platform

# Si true, crea tablas faltantes (IF NOT EXISTS) al iniciar backend
DB_SYNCHRONIZE=true

# Si true (defecto), aplica migraciones SQL pendientes en src/database/migrations/
DB_RUN_MIGRATIONS=true

# Semilla opcional de admin (si ambos están definidos)
DB_DEFAULT_ADMIN_USERNAME=
DB_DEFAULT_ADMIN_PASSWORD=

# Fallback a archivos solo si DATABASE_URL está vacío
INGEST_DATA_DIR=data

# Orígenes del panel (Next) para CORS — obligatorio para que el navegador hable con este Nest:
# CORS_ORIGINS=http://TU_IP_PUBLICA:3011
# (mismo esquema/host/puerto que uses para abrir el panel en el navegador)
CORS_ORIGINS=http://localhost:3011,http://127.0.0.1:3011
