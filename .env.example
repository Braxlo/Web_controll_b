PORT=3000

# Si se define, protege endpoints /api/ingest y PUT /api/config/devices
INGESTION_SECRET=

# PostgreSQL (opción A: URL completa)
# Ejemplo: postgresql://usuario:clave@localhost:5432/hkn_platform
DATABASE_URL=

# PostgreSQL (opción B: variables separadas)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=hkn_platform

# Si true, crea tablas faltantes (IF NOT EXISTS) al iniciar backend
DB_SYNCHRONIZE=true

# Semilla opcional de admin (si ambos están definidos)
DB_DEFAULT_ADMIN_USERNAME=
DB_DEFAULT_ADMIN_PASSWORD=

# Fallback a archivos solo si DATABASE_URL está vacío
INGEST_DATA_DIR=data
