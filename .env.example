# Puerto HTTP del Nest (mismo que uses en BACKEND_URL del frontend:…:PUERTO)
PORT=3010

# Si se define, exige Bearer = este valor o JWT de admin (panel). Coincide con INGESTION_SECRET del frontend (proxy).
INGESTION_SECRET=

# Firma de JWT para POST /api/auth/login y sesión del panel (distinto de INGESTION_SECRET).
JWT_SECRET=

# PostgreSQL (opción A: URL completa)
# Ejemplo: postgresql://usuario:clave@localhost:5432/hkn_platform
DATABASE_URL=

# PostgreSQL (opción B: variables separadas)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=hkn_platform

# Si true, crea tablas faltantes (IF NOT EXISTS) al iniciar backend
DB_SYNCHRONIZE=true

# Si true (defecto), aplica migraciones SQL pendientes en src/database/migrations/
DB_RUN_MIGRATIONS=true

# Semilla opcional de admin (si ambos están definidos)
DB_DEFAULT_ADMIN_USERNAME=
DB_DEFAULT_ADMIN_PASSWORD=

# Fallback a archivos solo si DATABASE_URL está vacío
INGEST_DATA_DIR=data

# Orígenes permitidos para llamadas al API desde el navegador (no afecta al proxy server-to-server del Next).
# Incluye la URL pública del front, ej: http://95.61.248.186:3011,http://localhost:3011
CORS_ORIGINS=http://localhost:3011,http://127.0.0.1:3011
